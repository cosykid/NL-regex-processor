# Copy to `.env` (docker compose reads it automatically) and adjust.

# --- LLM ---------------------------------------------------------------------
# Leave ANTHROPIC_API_KEY blank to run the deterministic heuristic fallback
# (the app works end-to-end with no key). Set it to enable LLM generation.
ANTHROPIC_API_KEY=
# NL->regex is a small task; Haiku is the default. Override for tougher prompts.
LLM_MODEL=claude-haiku-4-5
# A few real values per target column are shown to the LLM so patterns match the
# data's actual case/format (e.g. "False", not "false"). Defaults are usually fine.
# LLM_SAMPLE_VALUES_PER_COLUMN=10
# LLM_SAMPLE_VALUE_MAXLEN=80

# --- Django ------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# --- Database (Neon) ---------------------------------------------------------
# Neon is THE database — there is no local Postgres container and no SQLite
# fallback. Paste your Neon "pooled" connection string here, verbatim, from the
# Neon dashboard -> Connection Details (host contains "-pooler"). The database
# name and query params are read straight from the URL; TLS (sslmode=require)
# and channel_binding are honoured. The web container runs `migrate` on start.
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Object storage ----------------------------------------------------------
# Where uploaded files and Spark results live.
#   local (default) -> the DATA_DIR volume; no AWS needed.
#   s3              -> an S3 bucket provisioned by infra/terraform.
# Provision the bucket, then run `terraform output dotenv_snippet` and paste the
# result here. Credentials use the default AWS chain: the static keys below for
# local dev, or an attached IAM role when deployed (leave the keys blank then).
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=ap-southeast-2
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: point at an S3-compatible endpoint (MinIO / LocalStack).
S3_ENDPOINT_URL=

# --- Celery ------------------------------------------------------------------
CELERY_CONCURRENCY=2

# --- Spark -------------------------------------------------------------------
# Default: bundled Spark runtime in the worker (local[*]). To use the optional
# standalone cluster, run `docker compose --profile cluster up` AND set:
#   SPARK_MASTER_URL=spark://spark-master:7077
#   SPARK_DRIVER_HOST=worker
SPARK_MASTER_URL=local[*]
SPARK_DRIVER_HOST=
SPARK_ROWS_PER_PARTITION=200000
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g
