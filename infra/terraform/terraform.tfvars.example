# Copy to terraform.tfvars and adjust. All values have sensible defaults, so an
# empty tfvars works too — this just documents the common knobs.

region      = "ap-southeast-2"
name_prefix = "nl-regex-processor"
environment = "dev"

# Leave empty to auto-generate a globally-unique name; set to pin an exact one.
# bucket_name = "my-company-nl-regex-dev"

# --- dev vs prod ---
# Local development: keep true to get static access keys in the outputs.
# Deployed environments: set false and attach app_role_arn to your compute.
create_dev_user = true

# Dev convenience only — lets `terraform destroy` wipe a non-empty bucket.
# NEVER set true for prod.
force_destroy = false

# --- data protection ---
enable_versioning                  = true
sse_algorithm                      = "AES256" # or "aws:kms" (+ kms_key_arn)
noncurrent_version_expiration_days = 30
abort_incomplete_multipart_days    = 7

# Optional TTLs on user data (0 = keep forever).
# uploads_expiration_days = 30
# results_expiration_days = 7

# --- direct browser<->S3 uploads ---
# REQUIRED for the direct-to-S3 upload flow: the browser PUTs the file straight
# to the bucket, so the bucket must allow CORS from the app's origin(s). List
# every origin the frontend is served from (dev + prod). Empty = no CORS rule.
# cors_allowed_origins = ["http://localhost:8080", "https://app.example.com"]

# --- deployed trust (only relevant when create_dev_user = false) ---
# trusted_role_services = ["ecs-tasks.amazonaws.com", "ec2.amazonaws.com"]
#
# EKS IRSA example:
# oidc_provider_arn = "arn:aws:iam::123456789012:oidc-provider/oidc.eks.ap-southeast-2.amazonaws.com/id/EXAMPLED539D4633E53DE1B71EXAMPLE"
# oidc_subjects     = ["system:serviceaccount:default:nl-regex"]

# --- EC2 host (CI/CD deploy target) ---
# Setting ssh_public_key CREATES the instance (empty = skipped entirely).
# ssh_public_key   = "ssh-ed25519 AAAA... you@laptop"
# instance_type    = "t4g.large"        # ARM only — CI ships linux/arm64 images
# ssh_ingress_cidr = ["0.0.0.0/0"]      # narrow if you deploy from a fixed IP
# root_volume_gb   = 30

# --- spend guardrails ---
# Setting budget_alert_email CREATES a monthly AWS Budget (empty = skipped).
# Tracks GROSS spend (credits excluded) — set the limit at/below your
# remaining free-plan credits. Alerts at 50%/80%/100%; auto-STOPS the EC2
# instance at 90% unless budget_auto_stop = false.
# budget_alert_email = "you@example.com"
# budget_limit_usd   = 100
# budget_auto_stop   = true
